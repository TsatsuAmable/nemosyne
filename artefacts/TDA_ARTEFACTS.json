[
  {
    "artefact_id": "topo-persistence-barcode",
    "name": "Persistence Barcode",
    "tda_concept": "persistent_homology",
    "topology": "temporal-persistent",
    "description": "Visualizes birth and death of topological features across filtration scales",
    "geometry_template": {
      "base": "box",
      "variant": "horizontal-bar",
      "dimensions": {
        "height": 0.2,
        "depth": 0.1,
        "width_dynamic": "persistence_lifetime"
      }
    },
    "visual_encoding": {
      "x": "birth_scale",
      "y": "homology_dimension_encoded",
      "width": "persistence_lifetime",
      "color": {
        "dimension_0": "#1f77b4",
        "dimension_1": "#ff7f0e",
        "dimension_2": "#2ca02c",
        "high_persistence": "#d62728"
      }
    },
    "required_data": {
      "persistence_pairs": [
        {
          "dimension": 0,
          "birth": 0,
          "death": 1.5,
          "persistence": 1.5
        },
        {
          "dimension": 1,
          "birth": 0.8,
          "death": 2.2,
          "persistence": 1.4
        },
        {
          "dimension": 1,
          "birth": 2.5,
          "death": 6.0,
          "persistence": 3.5
        }
      ]
    },
    "behaviours": [
      "threshold-filter",
      "homology-dimension-toggle",
      "persistence-hover-detail",
      "diagonal-cut-highlight"
    ],
    "interactions": {
      "threshold_slider": "Filter features by minimum persistence",
      "dimension_checkbox": "Toggle H0, H1, H2 visibility",
      "bar_click": "Highlight in companion views (complex, mapper)",
      "diagonal_brush": "Select features by birth-death relationship"
    },
    "d3_scales": {
      "x": "scaleLinear().domain([min_birth, max_death]).range([0, 20])",
      "y": "scaleBand().domain([0, 1, 2]).range([0, 6])",
      "color": "Ordinal(H0=blue, H1=orange, H2=green)"
    }
  },
  {
    "artefact_id": "topo-simplicial-complex",
    "name": "Simplicial Complex",
    "tda_concept": "vietoris_rips_complex",
    "topology": "simplices",
    "description": "Mesh of points, edges, triangles, tetrahedra showing connectivity at a scale",
    "geometry_template": {
      "0-simplices": { "type": "sphere", "radius": 0.15 },
      "1-simplices": { "type": "cylinder", "radius": 0.02, "segments": 8 },
      "2-simplices": { "type": "plane", "opacity": 0.3, "doubleSided": true },
      "3-simplices": { "type": "tetrahedron", "opacity": 0.15 }
    },
    "visual_encoding": {
      "vertices": "0-simplices (data points)",
      "edges": "1-simplices (pairs within 2ε)",
      "triangles": "2-simplices (triples pairwise within 2ε)",
      "tetrahedra": "3-simplices (quadruples forming clique)"
    },
    "required_data": {
      "filtration_epsilon": 2.5,
      "vertices": [
        { "id": 0, "x": 0, "y": 0, "z": 0, "label": "A" },
