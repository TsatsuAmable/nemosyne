    "geometry_template": {
      "nodes": { "type": "sphere", "radius_dynamic": "cluster_size" },
      "edges": { "type": "curved-tube", "radius": 0.03 },
      "layout": "force-directed-3d"
    },
    "visual_encoding": {
      "node_position": "graph_layout_force_directed",
      "node_color": "filter_function_value",
      "node_size": "cluster_cardinality",
      "edge_thickness": "overlap_strength",
      "edge_color": "gradient_between_connected_nodes"
    },
    "required_data": {
      "filter_function": "lens_pca_component_1",
      "cover": {
        "num_intervals": 10,
        "overlap": 0.3
      },
      "clusters": [
        { "id": "I0_C0", "interval": 0, "points": [12, 15, 18, 22], "size": 4, "centroid": [-2.5, 0.1, 0] },
        { "id": "I0_C1", "interval": 0, "points": [45, 48, 52], "size": 3, "centroid": [-2.2, 0.8, 0.2] },
        { "id": "I1_C0", "interval": 1, "points": [15, 18, 22, 25, 28], "size": 5, "centroid": [-1.5, 0, 0] },
        { "id": "I2_C0", "interval": 2, "points": [78, 82, 85, 88], "size": 4, "centroid": [2.2, -0.5, 0] }
      ],
      "edges": [
        { "source": "I0_C0", "target": "I1_C0", "overlap_count": 3, "strength": 0.75 },
        { "source": "I1_C0", "target": "I2_C0", "overlap_count": 0, "strength": 0 }
      ]
    },
    "behaviours": [
      "cluster-expand",
      "filter-remap",
      "cover-adjust",
      "node-member-preview"
    ],
    "interactions": {
      "node_hover": "Preview cluster members",
      "node_click": "Expand to show full member list with original data",
      "edge_hover": "Show overlapping points",
      "lens_dropdown": "Change filter function (PCA, t-SNE, eccentricity, density)",
      "cover_sliders": "Adjust number of intervals and overlap"
    },
    "keen_parameters": {
      "n_intervals": "Number of lens interval bins",
      "overlap": "Percentage overlap between intervals",
      "clusterer": "DBSCAN, HDBSCAN, or Agglomerative"
    }
  },
  {
    "artefact_id": "topo-reeb-contours",
    "name": "Reeb Graph",
    "tda_concept": "reeb_graph",
    "topology": "level-set-evolution",
    "description": "Evolution of level set connected components across a scalar function",
    "geometry_template": {
      "critical_nodes": { "type": "sphere", "size": "type_dependent" },
      "contour_arcs": { "type": "tubular-mesh", "sections": "level_set_samples" },
      "layout": "monotone-path-y" 
    },
    "visual_encoding": {
      "y_position": "function_value",
      "critical_size": { "min": 0.2, "saddle": 0.15, "max": 0.25 },
      "critical_color": { "min": "#2ca02c", "saddle": "#ff7f0e", "max": "#d62728" },
      "arc_thickness": "contour_cardinality_at_sample"
    },
    "required_data": {
      "scalar_function": "height_above_ground",
      "domain": [0, 10],
      "critical_points": [
        { "id": "cp_0", "type": "minimum", "value": 0.5, "position": [5, 0.5, 5], "index": 0 },
        { "id": "cp_1", "type": "saddle", "value": 3.2, "position": [7, 3.2, 3], "index": 1 },
        { "id": "cp_2", "type": "saddle", "value": 5.8, "position": [3, 5.8, 7], "index": 2 },
        { "id": "cp_3", "type": "maximum", "value": 8.5, "position": [5, 8.5, 5], "index": 3 }
      ],
      "contour_segments": [
        { 
          "from": "cp_0", 
          "to": "cp_1", 
          "samples": [
            { "value": 0.5, "contours": [{ "size": 1, "boundary": "single" }] },
            { "value": 1.5, "contours": [{ "size": 5, "boundary": "single" }] },
            { "value": 2.5, "contours": [{ "size": 12, "boundary": "single" }] }
          ]
        },
        {
          "from": "cp_1",
          "to": "cp_2",
          "branches": ["left", "right"],
          "samples": [
            { "value": 3.5, "contours": [{ "size": 8 }, { "size": 6 }] },
            { "value": 4.5, "contours": [{ "size": 10 }, { "size": 7 }] }
          ]
        }
      ]
    },
    "behaviours": [
      "level-slice-scrub",
      "merge-split-animation",
      "contour-surface-display",
      "critical-neighborhood-zoom"
    ],
    "interactions": {
      "horizontal_slider": "Move level set slice through function range",
      "critical_click": "Zoom to critical point, show Morse neighborhood",
      "branch_hover": "Highlight descendant/ancestor paths",
      "animate_play": "Animate sweep through function values"
    },
    "morse_theory": "Critical points (index 0=min, 1=saddle, 2=max) + level set evolution"
  },
  {
    "artefact_id": "topo-umap-manifold",
