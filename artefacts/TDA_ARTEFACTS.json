        { "id": 2, "x": 1.2, "y": 1.8, "z": 0.2, "label": "C" },
        { "id": 3, "x": 2.8, "y": 1.5, "z": 0.5, "label": "D" },
        { "id": 4, "x": 1.5, "y": 0.5, "z": 1.8, "label": "E" }
      ],
      "edges": [[0, 1], [0, 2], [1, 2], [1, 3], [2, 3], [2, 4], [3, 4]],
      "triangles": [[0, 1, 2], [1, 2, 3]],
      "tetrahedra": []
    },
    "behaviours": [
      "epsilon-scrub",
      "simplex-hover-highlight",
      "boundary-edge-glow",
      "cycle-detection-pulse"
    ],
    "interactions": {
      "epsilon_slider": "Adjust ε, watch simplices appear/disappear",
      "simplex_hover": "Show constituent vertices/edges/facets",
      "simplex_click": "Expand to show neighborhood",
      "homology_mode": "Highlight cycles (H1), cavities (H2), components (H0)"
    },
    "tda_computation": "ripser, gudhi, or scikit-tda"
  },
  {
    "artefact_id": "topo-mapper-network",
    "name": "Mapper Graph",
    "tda_concept": "mapper_algorithm",
    "topology": "graph-cluster",
