{
  "name": "nemosyne",
  "version": "1.1.0",
  "description": "Data-native VR visualization framework for WebXR",
  "type": "module",
  "main": "dist/nemosyne.js",
  "module": "dist/nemosyne.esm.js",
  "types": "dist/types/index.d.ts",
  "bin": {
    "nemosyne": "./bin/nemosyne-cli.js"
  },
  "files": [
    "bin/",
    "dist/",
    "src/",
    "examples/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "webpack serve --mode development --config webpack.config.cjs",
    "build": "npm run build:umd && npm run build:esm && npm run build:types",
    "build:umd": "webpack --mode production --config webpack.config.cjs",
    "build:esm": "rollup -c rollup.config.js",
    "build:types": "tsc -p tsconfig.declarations.json",
    "typecheck": "tsc -p tsconfig.declarations.json --noEmit",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "test:unit": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch",
    "test:coverage": "jest --coverage --collectCoverageFrom='src/**/*.js' --coverageThreshold='{\"global\":{\"branches\":95,\"functions\":95,\"lines\":95,\"statements\":95}}'",
    "test:integration": "playwright test tests/integration/",
    "test:integration:ui": "playwright test --ui",
    "lint": "eslint src/",
    "docs": "jsdoc -c jsdoc.json",
    "docs:build": "npm run docs",
    "build:examples": "echo 'No examples build configured' && exit 0",
    "test:comprehensive": "echo 'No comprehensive tests configured' && exit 0"
  },
  "keywords": [
    "vr",
    "webxr",
    "visualization",
    "data-visualization",
    "aframe",
    "threejs",
    "physics",
    "memories",
    "data-native"
  ],
  "author": "Tsatsu Amable",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TsatsuAmable/nemosyne.git"
  },
  "bugs": {
    "url": "https://github.com/TsatsuAmable/nemosyne/issues"
  },
  "homepage": "https://github.com/TsatsuAmable/nemosyne#readme",
  "peerDependencies": {
    "aframe": "^1.7.0",
    "ammo.js": "^0.0.10"
  },
  "peerDependenciesMeta": {
    "ammo.js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/core": "^7.21.0",
    "@babel/preset-env": "^7.21.0",
    "@playwright/test": "^1.59.1",
    "babel-loader": "^9.1.2",
    "commander": "^12.1.0",
    "eslint": "^8.36.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^30.3.0",
    "jsdoc": "^4.0.2",
    "rollup": "^3.20.0",
    "typescript": "^5.9.3",
    "webpack": "^5.76.0",
    "webpack-cli": "^5.0.1",
    "webpack-dev-server": "^4.13.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}
