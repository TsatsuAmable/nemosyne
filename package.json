{
  "name": "nemosyne",
  "version": "1.1.0",
  "description": "Data-native VR visualization framework for WebXR",
  "main": "dist/nemosyne.js",
  "module": "dist/nemosyne.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "src/",
    "examples/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "webpack serve --mode development",
    "build": "npm run build:umd && npm run build:esm",
    "build:umd": "webpack --mode production",
    "build:esm": "rollup -c rollup.config.js",
    "test": "jest --testPathPattern='nemosyne.test.js'",
    "test:unit": "jest --testPathPattern='nemosyne.test.js'",
    "test:watch": "jest --watch --testPathPattern='nemosyne.test.js'",
    "lint": "eslint src/",
    "docs": "jsdoc -c jsdoc.json"
  },
  "keywords": [
    "vr",
    "webxr",
    "visualization",
    "data-visualization",
    "aframe",
    "threejs",
    "physics",
    "memories",
    "data-native"
  ],
  "author": "Tsatsu Amable",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TsatsuAmable/nemosyne.git"
  },
  "bugs": {
    "url": "https://github.com/TsatsuAmable/nemosyne/issues"
  },
  "homepage": "https://github.com/TsatsuAmable/nemosyne#readme",
  "peerDependencies": {
    "aframe": "^1.7.0",
    "ammo.js": "^0.0.10"
  },
  "peerDependenciesMeta": {
    "ammo.js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/core": "^7.21.0",
    "@babel/preset-env": "^7.21.0",
    "babel-loader": "^9.1.2",
    "eslint": "^8.36.0",
    "jest": "^29.5.0",
    "jsdoc": "^4.0.2",
    "rollup": "^3.20.0",
    "webpack": "^5.76.0",
    "webpack-cli": "^5.0.1",
    "webpack-dev-server": "^4.13.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}
