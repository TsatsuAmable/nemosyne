{
  "id": "hello-crystal",
  "name": "Hello World Crystal",
  "version": "0.1.0",
  "description": "A faceted crystalline node representing a single scalar value",
  "topology": "scalar",
  "primitive": "crystal",
  "geometry": {
    "type": "octahedron",
    "radius": 1
  },
  "material": {
    "shader": "standard",
    "properties": {
      "color": "#00d4aa",
      "emissive": "#00d4aa",
      "emissiveIntensity": 0.5,
      "metalness": 0.8,
      "roughness": 0.2
    }
  },
  "transform": {
    "scale": { "$data": "value", "$range": [0.5, 1.5] }
  },
  "behaviours": [
    {
      "trigger": "hover",
      "action": "glow",
      "params": { "intensity": 2.0, "duration": 0.3 }
    },
    {
      "trigger": "hover-leave",
      "action": "glow",
      "params": { "intensity": 0.5, "duration": 0.3 }
    },
    {
      "trigger": "click",
      "action": "scale",
      "params": { "factor": 1.3, "duration": 0.2 }
    },
    {
      "trigger": "idle",
      "action": "rotate",
      "params": { "speed": 0.5, "axis": "y" }
    }
  ],
  "labels": {
    "primary": {
      "content": { "$data": "label" },
      "position": "above",
      "visible": { "$trigger": "click" },
      "duration": 3.0
    }
  }
}