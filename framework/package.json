{
  "name": "nemosyne",
  "version": "0.2.0",
  "description": "VR Artefacts for Real-World Data — A framework for creating interactive 3D data visualizations in A-Frame",
  "main": "dist/nemosyne.iife.js",
  "module": "dist/nemosyne.es.js",
  "unpkg": "dist/nemosyne.min.iife.js",
  "jsdelivr": "dist/nemosyne.min.iife.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/nemosyne.es.js",
      "require": "./dist/nemosyne.umd.js",
      "browser": "./dist/nemosyne.iife.js"
    },
    "./v2": {
      "import": "./dist/nemosyne.es.js",
      "require": "./dist/nemosyne.umd.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "node scripts/build.js",
    "build:quick": "vite build",
    "build:types": "tsc --declaration --emitDeclarationOnly --outDir dist",
    "release": "node scripts/release.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .js,.ts",
    "lint:fix": "eslint src --ext .js,.ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview",
    "clean": "rm -rf dist/ releases/"
  },
  "keywords": [
    "vr",
    "data-visualization",
    "aframe",
    "webxr",
    "3d",
    "charts",
    "graphs",
    "data",
    "webgl",
    "threejs"
  ],
  "author": "TsatsuAmable",
  "license": "MIT",
  "engines": {
    "node": ">=14.0.0"
  },
  "peerDependencies": {
    "aframe": "^1.4.0"
  },
  "dependencies": {
    "d3-scale": "^4.0.2",
    "d3-color": "^3.1.0",
    "d3-array": "^3.2.0"
  },
  "devDependencies": {
    "@types/aframe": "^1.2.0",
    "@types/d3": "^7.4.0",
    "@types/node": "^20.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "terser": "^5.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/TsatsuAmable/nemosyne.git"
  },
  "bugs": {
    "url": "https://github.com/TsatsuAmable/nemosyne/issues"
  },
  "homepage": "https://nemosyne.world"
}
